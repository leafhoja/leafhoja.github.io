{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🔒 サイトをロック（全ページ閲覧不可）",
      "type": "shell",
      "command": "node toggle-lock.js lock",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "🔓 サイトを公開する",
      "type": "shell",
      "command": "node toggle-lock.js unlock",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "📋 サイトのロック状態を確認",
      "type": "shell",
      "command": "node toggle-lock.js status",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    }
  ]
}
